{
  "name": "website",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.4",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/marked": "^5.0.2",
    "@types/node": "^24",
    "@types/three": "^0.184.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@melt-ui/svelte": "~0.86.6",
    "@tanstack/svelte-query": "^6.1.29",
    "@tanstack/svelte-table": "9.0.0-alpha.48",
    "@threlte/core": "^8.5.13",
    "@threlte/extras": "^9.15.2",
    "elastic-builder": "2.31.0",
    "highlight.js": "^11.11.1",
    "marked": "^5.1.2",
    "motion": "12.5.0",
    "nanoid": "5.1.4",
    "three": "^0.184.0",
    "zod": "^3.24.1"
  }
}
